#!/usr/bin/env bash
# harness-init — deterministic scaffolder invoked by /harness-kit:init.
# Detects or takes a project type (godot|web|custom), writes .harness/config.json
# + rubric + plan/docs skeleton, a state .gitignore, and an in-repo git pre-commit
# wired via core.hooksPath. Idempotent: never clobbers an existing config unless
# --force. The skill handles type DETECTION/ambiguity; this handles the file ops.
#
# Usage: harness-init [godot|web|custom] [--force]
set -uo pipefail
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TPL="$BIN_DIR/../templates"
# shellcheck source=../scripts/lib/config.sh
source "$BIN_DIR/../scripts/lib/config.sh"

TYPE=""; FORCE=0
for a in "$@"; do
  case "$a" in
    --force) FORCE=1 ;;
    godot|web|custom) TYPE="$a" ;;
    *) echo "harness-init: unknown arg '$a'"; exit 2 ;;
  esac
done

PROJ="$HARNESS_PROJECT_DIR"
cd "$PROJ" || { echo "harness-init: cannot cd to project root"; exit 1; }

# Auto-detect when type not supplied.
if [ -z "$TYPE" ]; then
  if [ -f project.godot ]; then TYPE="godot"
  elif [ -f package.json ]; then TYPE="web"
  else echo "harness-init: could not auto-detect project type. Pass godot|web|custom."; exit 2; fi
fi

echo "harness-init: project=$PROJ type=$TYPE"
mkdir -p .harness

# --- config.json ---
SRC="$TPL/$TYPE/config.json"
if [ -f .harness/config.json ] && [ "$FORCE" -ne 1 ]; then
  echo "  .harness/config.json exists — keeping (use --force to reset)"
elif [ "$TYPE" = "custom" ]; then
  cat > .harness/config.json <<'J'
{
  "projectType": "custom",
  "verificationMode": "strict",
  "gates": [
    { "name": "doc-links", "command": "harness-doc-links", "blocking": true },
    { "name": "plan-dod", "command": "harness-check-plan-dod", "blocking": true }
  ],
  "layeringRules": [],
  "plan": { "dir": "docs/plans", "codeGlob": "", "statusField": "status", "completedValue": "completed", "checklistRegex": "^- \\[ \\]" },
  "docs": { "scanRoots": ["docs"] },
  "metrics": [ { "name": "completed", "glob": "docs/plans/completed/*.md", "exclude": "gitkeep" } ],
  "phases": [ { "name": "Phase 0 — Bootstrap", "when": [], "capabilities": ["base gates"] } ],
  "loopDetection": { "threshold": 5 },
  "evaluator": { "enabled": false }
}
J
  echo "  wrote .harness/config.json (custom skeleton — edit gates/layeringRules for your stack)"
else
  cp "$SRC" .harness/config.json
  echo "  wrote .harness/config.json ($TYPE preset)"
fi

# --- rubric.md ---
RUB="$TPL/$TYPE/rubric.md"
if [ -f "$RUB" ]; then
  if [ -f .harness/rubric.md ] && [ "$FORCE" -ne 1 ]; then
    echo "  .harness/rubric.md exists — keeping"
  else
    cp "$RUB" .harness/rubric.md
    echo "  wrote .harness/rubric.md"
  fi
fi

# --- plan + docs skeleton (create only what's missing) ---
PLAN_DIR=$(harness_cfg_get plan.dir "docs/plans")
mkdir -p "$PLAN_DIR/active" "$PLAN_DIR/completed"
[ -f "$PLAN_DIR/active/.gitkeep" ] || touch "$PLAN_DIR/active/.gitkeep"
[ -f "$PLAN_DIR/completed/.gitkeep" ] || touch "$PLAN_DIR/completed/.gitkeep"
[ -f "$PLAN_DIR/_template.md" ] || cp "$TPL/plan-template.md" "$PLAN_DIR/_template.md" 2>/dev/null || true
echo "  plan dirs: $PLAN_DIR/{active,completed}"

# --- gitignore for the gitignored state dir ---
printf 'state/\n' > .harness/.gitignore

# --- in-repo git pre-commit (plugin cache isn't in the repo, so the hook body lives here) ---
mkdir -p .harness/hooks
cat > .harness/hooks/pre-commit <<H
#!/usr/bin/env bash
# harness-kit VCS gate — runs the same verify orchestrator before each commit.
# Tries PATH first (works inside Claude Code), falls back to the plugin path baked
# at init time. If the plugin moved/updated, re-run: /harness-kit:init --force
if command -v harness-verify >/dev/null 2>&1; then exec harness-verify; fi
exec "$BIN_DIR/harness-verify"
H
chmod +x .harness/hooks/pre-commit
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git config core.hooksPath .harness/hooks && echo "  git core.hooksPath -> .harness/hooks"
fi

echo "  ✓ harness-kit initialized ($TYPE). Next: /harness-kit:verify"
