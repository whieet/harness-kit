#!/usr/bin/env bash
# harness-trace-analyze — post-session analysis of harness behavior + config suggester.
# Self-contained: reads the harness's own project-local, gitignored state:
#   .harness/state/trace.jsonl  — session_start / session_end{result} /
#                                  tool_call{tool,file} / tool_fail{tool} /
#                                  gate{name,ok} / evaluator{dims,verdict}
#   .harness/state/loop-*.json  — per-file edit counts per session (churn)
#
# Surfaces failure-pattern signals AND falsifiable, signal-grounded config
# suggestions (the "self-iteration" successor to the old maturity-phase router:
# the user decides; the harness only suggests).
#
# Usage:
#   harness-trace-analyze            human report
#   harness-trace-analyze --json     machine-readable
#   harness-trace-analyze --suggest  ONLY the suggestion lines (empty if none)
set -uo pipefail
LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts/lib" && pwd)"
# shellcheck source=../scripts/lib/config.sh
source "$LIB/config.sh"
cd "$HARNESS_PROJECT_DIR" 2>/dev/null || exit 0

MODE="${1:-text}"
STATE_DIR="$(harness_state_dir)"

STATE_DIR="$STATE_DIR" MODE="$MODE" python3 <<'PYEOF'
import json, os, glob
from collections import Counter, defaultdict

state_dir = os.environ["STATE_DIR"]
mode = os.environ["MODE"]

trace = os.path.join(state_dir, "trace.jsonl")
records = []
if os.path.exists(trace):
    for line in open(trace, errors="replace"):
        line = line.strip()
        if not line:
            continue
        try:
            records.append(json.loads(line))
        except Exception:
            pass

started = sum(1 for r in records if r.get("event") == "session_start")
ended = [r for r in records if r.get("event") == "session_end"]
passed = sum(1 for r in ended if r.get("result") == "passed")
failed = sum(1 for r in ended if r.get("result") in ("failed", "advisory_fail"))

tool_calls = [r for r in records if r.get("event") == "tool_call"]
tool_fails = [r for r in records if r.get("event") == "tool_fail"]
EDIT_TOOLS = {"Edit", "Write", "MultiEdit", "NotebookEdit"}

# churn from loop-state files
churn = Counter()
for f in glob.glob(os.path.join(state_dir, "loop-*.json")):
    try:
        for fp, c in json.load(open(f)).items():
            churn[fp] = max(churn[fp], c)
    except Exception:
        pass

# repeated-tool pattern: same tool >=3 consecutive in the call sequence
seq = [r.get("tool", "") for r in tool_calls]
repeated = []
i = 0
while i < len(seq):
    j = i
    while j < len(seq) and seq[j] == seq[i]:
        j += 1
    if seq[i] and (j - i) >= 3 and seq[i] not in repeated:
        repeated.append(seq[i])
    i = j

# heavy-editing per session (proxy for late-verification): split by session_start
edits_per_session, cur = [], 0
saw_session = False
for r in records:
    ev = r.get("event")
    if ev == "session_start":
        if saw_session:
            edits_per_session.append(cur)
        cur, saw_session = 0, True
    elif ev == "tool_call" and r.get("tool") in EDIT_TOOLS:
        cur += 1
if saw_session:
    edits_per_session.append(cur)
heavy_sessions = [n for n in edits_per_session if n > 15]

# per-gate outcomes (gate{name,ok}) and evaluator dims (evaluator{dims:{dim:score}})
gate_runs, gate_fails = Counter(), Counter()
for r in records:
    if r.get("event") == "gate":
        gate_runs[r.get("name", "?")] += 1
        if not r.get("ok", True):
            gate_fails[r.get("name", "?")] += 1
dim_runs, dim_low = Counter(), Counter()
for r in records:
    if r.get("event") == "evaluator":
        for dim, score in (r.get("dims") or {}).items():
            dim_runs[dim] += 1
            try:
                if float(score) < 3:
                    dim_low[dim] += 1
            except (TypeError, ValueError):
                pass

# ---- signals ----
signals = []
if started > len(ended) + 2:
    signals.append(("medium", "session_imbalance",
                    "%d sessions started vs %d ended — possible crashes/interrupts" % (started, len(ended))))
if (passed + failed) > 0 and failed > passed:
    signals.append(("high", "verify_failure_rate",
                    "%d failed vs %d passed completion gates — issues caught late" % (failed, passed)))
if tool_calls and len(tool_fails) * 4 >= len(tool_calls):
    signals.append(("high", "tool_failure_rate",
                    "%d tool failures in %d calls — stack/tooling instability" % (len(tool_fails), len(tool_calls))))
for t in repeated:
    signals.append(("medium", "repeated_tool_pattern",
                    "%s called >=3x consecutively — possible loop or tool not returning what's expected" % t))
for fp, c in churn.most_common(10):
    if c >= 5:
        signals.append(("medium", "high_churn", "%s edited %dx in a session — possible doom loop" % (fp, c)))
if heavy_sessions:
    signals.append(("low", "heavy_editing",
                    "%d session(s) with >15 edits — verify incrementally, not all-at-once" % len(heavy_sessions)))

# ---- suggestions (falsifiable, user decides) ----
suggestions = []
for name, runs in gate_runs.items():
    if runs >= 5 and gate_fails[name] == 0:
        suggestions.append("gate '%s' failed 0/%d runs — if it adds overhead, consider removing it from gates[] or marking tier:fast." % (name, runs))
for dim, runs in dim_runs.items():
    if runs >= 3 and dim_low[dim] * 2 > runs:
        suggestions.append("evaluator dimension '%s' scored <3 in %d/%d runs — rubric may be too strict, or a real capability gap." % (dim, dim_low[dim], runs))
if any(t for t in repeated):
    suggestions.append("repeated-tool loops seen — consider lowering loopDetection.threshold or adding a gate covering that area.")
if (passed + failed) > 0 and failed > passed:
    suggestions.append("completion gate fails more than it passes — run /harness-kit:verify earlier (mid-task), don't leave it to the Stop gate.")

if mode == "--suggest":
    for s in suggestions:
        print(s)
elif mode == "--json":
    print(json.dumps({
        "sessions_started": started, "sessions_ended": len(ended),
        "gate_passed": passed, "gate_failed": failed,
        "tool_calls": len(tool_calls), "tool_fails": len(tool_fails),
        "top_churn": [{"file": f, "edits": c} for f, c in churn.most_common(10)],
        "repeated_tools": repeated,
        "gate_outcomes": {n: {"runs": gate_runs[n], "fails": gate_fails[n]} for n in gate_runs},
        "signals": [{"severity": s, "type": t, "detail": d} for s, t, d in signals],
        "suggestions": suggestions,
    }, ensure_ascii=False, indent=2))
else:
    print("=== Harness trace analysis ===")
    print("  sessions: started=%d ended=%d" % (started, len(ended)))
    print("  completion gate: passed=%d failed=%d" % (passed, failed))
    print("  tool calls=%d fails=%d" % (len(tool_calls), len(tool_fails)))
    if churn:
        print("  most-churned files:")
        for f, c in churn.most_common(5):
            print("    %s: %d" % (f, c))
    if signals:
        print("  signals:")
        icon = {"high": "🔴", "medium": "🟡", "low": "🟢"}
        for s, t, d in signals:
            print("    %s [%s] %s" % (icon.get(s, "⚪"), t, d))
    else:
        print("  signals: none — harness running healthy")
    if suggestions:
        print("  suggestions (you decide):")
        for s in suggestions:
            print("    - " + s)
PYEOF
