#!/usr/bin/env bash
# harness-doc-gardening — thin launcher; real implementation lives in scripts/harness/commands/.
# See scripts/run-hook for the dispatcher protocol.
set -uo pipefail
HARNESS_KIT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
HARNESS_DISPATCH="harness-doc-gardening"
export HARNESS_KIT_ROOT HARNESS_DISPATCH
# shellcheck source=../scripts/lib/pyfind.sh
source "$HARNESS_KIT_ROOT/scripts/lib/pyfind.sh" "$@"
